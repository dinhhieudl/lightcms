# Z-Core Environment Configuration
# Copy to .env and customize

# App
ZCORE_APP_NAME=My Store
ZCORE_DEBUG=false
ZCORE_HOST=0.0.0.0
ZCORE_PORT=8000
ZCORE_SECRET_KEY=change-me-openssl-rand-hex-32

# Site
ZCORE_SITE_URL=https://your-domain.com
ZCORE_SITE_TITLE=My Store
ZCORE_SITE_DESCRIPTION=Your store description
ZCORE_SITE_LANGUAGE=vi

# Admin
ZCORE_ADMIN_PREFIX=/admin

# Database
ZCORE_DB_PATH=data/zcore.db

# Telegram Notifications
ZCORE_TELEGRAM_BOT_TOKEN=
ZCORE_TELEGRAM_CHAT_ID=

# Email SMTP
ZCORE_SMTP_HOST=
ZCORE_SMTP_PORT=587
ZCORE_SMTP_USER=
ZCORE_SMTP_PASS=
ZCORE_SMTP_FROM=

# Uploads
ZCORE_MAX_UPLOAD_MB=10
ZCORE_WEBP_QUALITY=85

# WordPress Migration (source)
WP_MYSQL_HOST=localhost
WP_MYSQL_PORT=3306
WP_MYSQL_DB=wordpress
WP_MYSQL_USER=root
WP_MYSQL_PASS=
WP_TABLE_PREFIX=wp_
